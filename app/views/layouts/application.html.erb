<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= t("app.title") %></title>
    <style>
      :root {
        --bg: #fafafa;
        --fg: #0f172a;
        --muted: #64748b;
        --border: #e5e7eb;
        --accent: #2563eb;
        --accent-soft: #eff6ff;
        --card-bg: #ffffff;
        --code-bg: #0f172a;
        --code-fg: #e2e8f0;
        --code-comment: #64748b;
      }
      * { box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", sans-serif;
        margin: 0;
        background: var(--bg);
        color: var(--fg);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--border);
        background: #fff;
      }
      .wordmark { font-weight: 600; font-size: 0.95rem; letter-spacing: -0.01em; }
      .lang-switcher a {
        margin-left: 0.25rem;
        padding: 0.3rem 0.6rem;
        font-size: 0.78rem;
        font-weight: 500;
        color: var(--muted);
        text-decoration: none;
        border-radius: 6px;
        transition: background 0.15s, color 0.15s;
      }
      .lang-switcher a:hover { background: var(--border); color: var(--fg); }
      .lang-switcher a.active { background: var(--fg); color: #fff; }
      .container {
        max-width: 980px;
        margin: 0 auto;
        padding: 3.5rem 1.5rem 4rem;
      }
      .hero { margin-bottom: 2rem; }
      .badge {
        display: inline-block;
        padding: 0.3rem 0.75rem;
        border: 1px solid var(--border);
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--muted);
        margin-bottom: 1.25rem;
        background: #fff;
      }
      .hero h1 {
        font-size: 2.5rem;
        font-weight: 600;
        line-height: 1.15;
        letter-spacing: -0.02em;
        margin: 0 0 1rem;
        max-width: 720px;
      }
      .hero-description {
        font-size: 1.1rem;
        color: var(--muted);
        max-width: 620px;
        margin: 0;
      }
      .callout {
        padding: 1rem 1.25rem;
        border-left: 3px solid var(--accent);
        background: var(--accent-soft);
        border-radius: 4px;
        margin: 0 0 3rem;
        font-size: 0.95rem;
      }
      .sections-title {
        font-size: 1.5rem;
        font-weight: 600;
        margin: 0 0 1.5rem;
        letter-spacing: -0.01em;
      }
      .cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1rem;
      }
      .card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
      }
      .eyebrow {
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }
      .card h3 {
        font-size: 1.15rem;
        font-weight: 600;
        margin: 0.5rem 0 0.75rem;
        letter-spacing: -0.01em;
      }
      .card p {
        color: var(--muted);
        font-size: 0.92rem;
        margin: 0 0 1.25rem;
      }
      .card pre {
        background: var(--code-bg);
        color: var(--code-fg);
        padding: 0.9rem 1rem;
        border-radius: 6px;
        font-size: 0.78rem;
        line-height: 1.5;
        overflow-x: auto;
        margin: auto 0 0;
      }
      .card pre code {
        font-family: ui-monospace, SFMono-Regular, "SF Mono", Consolas, monospace;
      }
      .card pre .comment { color: var(--code-comment); }
      .demo {
        background: #f8fafc;
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 0.5rem 1rem;
        margin: auto 0 0;
        font-size: 0.92rem;
      }
      .demo-row { padding: 0.5rem 0; }
      .demo-row + .demo-row { border-top: 1px solid var(--border); }
      .page-footer {
        margin-top: 3rem;
        padding-top: 1.75rem;
        border-top: 1px solid var(--border);
        font-size: 0.9rem;
      }
      .page-footer a { color: var(--accent); text-decoration: none; font-weight: 500; }
      .page-footer a:hover { text-decoration: underline; }
      @media (max-width: 600px) {
        .hero h1 { font-size: 1.85rem; }
        .container { padding: 2rem 1rem 3rem; }
      }
    </style>
  </head>
  <body>
    <header class="topbar">
      <div class="wordmark"><%= t("app.title") %></div>
      <nav class="lang-switcher">
        <% I18n.available_locales.each do |locale| %>
          <%= link_to locale.upcase, url_for(locale: locale), class: (I18n.locale == locale ? "active" : nil) %>
        <% end %>
      </nav>
    </header>
    <div class="container">
      <%= yield %>
    </div>
  </body>
</html>
